# ============================================
# GitHub → ClickUp Automation - Configuração
# ============================================
# Copie este arquivo para .env e preencha os valores.
#   cp .env.example .env

# ----- GitHub -----
# Token de acesso pessoal (classic ou fine-grained)
# Permissões necessárias: repo (read issues)
# Gere em: https://github.com/settings/tokens
GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE

# Repositório alvo no formato "owner/repo"
GITHUB_REPO=seu-usuario/seu-repositorio

# ----- ClickUp -----
# API Key pessoal do ClickUp
# Gere em: ClickUp → Settings → Apps → API Token
CLICKUP_API_TOKEN=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID da List onde as tasks serão criadas
# Encontre em: ClickUp → List → Settings → List ID (ou via API)
CLICKUP_LIST_ID=900000000000

# ----- Gemini (IA - Google) -----
# Chave da API do Google Gemini para o agente de decisão
# Gere em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo a ser usado (ex: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# ----- Scheduler -----
# Intervalo do cron em minutos (padrão: 60)
SCHEDULER_INTERVAL_MINUTES=60

# ----- Geral -----
# Nível de log: debug | info | warn | error
LOG_LEVEL=info
